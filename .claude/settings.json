{
  "cleanupPeriodDays": 7,
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "Bash(gemini:*)",
      "Bash(docker logs:*)",
      "Bash(docker exec:*)",
      "Bash(docker-compose stop:*)",
      "Bash(docker rm:*)",
      "Bash(docker volume rm:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn format:*)",
      "Bash(yarn build:*)",
      "Bash(yarn test:*)",
      "Bash(yarn start:*)",
      "Bash(yarn add:*)",
      "Bash(yarn remove:*)",
      "Bash(yarn typeorm:*)",
      "Bash(yarn lint:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx typeorm:*)",
      "Bash(make:*)",
      "Bash(wc:*)",
      "Bash(curl:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ],
    "ask": ["Bash(git push:*)"]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE_PATH=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.file_path // empty'); if [ -n \"$FILE_PATH\" ] && echo \"$FILE_PATH\" | grep -qE '\\.(env|pem|key|secret|credentials)'; then echo 'BLOCKED: Cannot write to sensitive files (.env, .pem, .key, .secret, .credentials)' >&2; exit 2; fi; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/.claude/hentai-voice.aiff"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "preferences": {
    "tmuxSplitPanes": true
  }
}
